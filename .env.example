SEED_ACCOUNTANT_PARIS_PASSWORD=ChangeMe!Paris2026
SEED_ACCOUNTANT_BORDEAUX_EMAIL=accountant.bordeaux@halalfoodservice.fr
SEED_ACCOUNTANT_BORDEAUX_PASSWORD=ChangeMe!Bordeaux2026
SEED_ACCOUNTANT_LYON_EMAIL=accountant.lyon@halalfoodservice.fr
