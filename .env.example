# --- Runtime ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# --- Master DB (shared: companies, users, roles, permissions, audit) ---
MASTER_MONGO_URI=mongodb://127.0.0.1:27017/hff_master

# --- Tenant Mongo URIs (used at seed time only; afterwards stored encrypted in Company doc) ---
TENANT_PARIS_MONGO_URI=mongodb://127.0.0.1:27017/hff_paris
TENANT_BORDEAUX_MONGO_URI=mongodb://127.0.0.1:27017/hff_bordeaux
TENANT_LYON_MONGO_URI=mongodb://127.0.0.1:27017/hff_lyon

# --- SAP Service Layer (placeholders for seed; rotated in-app afterwards) ---
SAP_BASE_URL_PARIS=https://your-sap-host:50000/b1s/v1
SAP_BASE_URL_BORDEAUX=https://your-sap-host:50000/b1s/v1
SAP_BASE_URL_LYON=https://your-sap-host:50000/b1s/v1
SAP_COMPANY_DB_PARIS=MSF_HALAL_LIVE_NEW
SAP_COMPANY_DB_BORDEAUX=A19865_HALAL_FOODSERVICE_BORDEAUX_NEW
SAP_COMPANY_DB_LYON=A19865_HALAL_FOODSERVICE_LYON_NEW
SAP_USERNAME_PARIS=
SAP_PASSWORD_PARIS=
SAP_USERNAME_BORDEAUX=
SAP_PASSWORD_BORDEAUX=
SAP_USERNAME_LYON=
SAP_PASSWORD_LYON=

# --- Crypto ---
# 32-byte hex (64 chars) for AES-256-GCM. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_me_with_64_hex_chars_64_hex_chars_64_hex_chars_64_hexx

# --- Auth ---
JWT_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars
COOKIE_NAME=hff_session
CSRF_COOKIE_NAME=hff_csrf
COOKIE_DOMAIN=
COOKIE_SECURE=false
SESSION_TTL_HOURS=8

# --- CORS / Frontend ---
CLIENT_ORIGIN=http://localhost:5173

# --- Seed users (initial admin set; change passwords after first login) ---
SEED_SOHAIB_EMAIL=sohaibsipra32@gmail.com
SEED_SOHAIB_PASSWORD=ChangeMe!Sohaib2026
SEED_IDRIS_EMAIL=idris@halalfoodservice.fr
SEED_IDRIS_PASSWORD=ChangeMe!Idris2026
